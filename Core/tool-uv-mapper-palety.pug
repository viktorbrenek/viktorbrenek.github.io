doctype html
head
  title UV Mapper shader palety | Viktor Břenek
  meta(content="text/html;charset=utf-8", http-equiv="Content-Type")
  meta(content="utf-8", http-equiv="encoding")
  meta(name="author" content="Viktor Brenek")
  meta(name="description" content="Přemapování UV modelu do omezené shader palety podle původní textury")
  meta(property="og:image" content="http://viktorbrenek.github.io/assets/images/icon-512.png")
  meta(name="viewport" content="width=device-width,initial-scale=1.0")
  link(rel="stylesheet", href="styles.css")
  link(rel="icon" href="assets/images/favicon.png" sizes="any")
  link(rel="icon" href="assets/images/icon.svg" type="image/svg+xml")
  link(rel="apple-touch-icon" href="assets/images/apple-touch-icon.png")
  link(rel="manifest" href="/manifest.json")
  script(src="site.js" defer)
  script(type="importmap").
    {
      "imports": {
        "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
      }
    }
  script(type="module" src="uv-palette-mapper.js")

body(data-page="tool-uv-mapper")
  header.site-header
    .site-header__inner
      a.brand(href="index.html")
        span.brand__sigil V
        span.brand__text
          span.brand__eyebrow Nástroje
          span.brand__name Viktor Břenek
      button.nav-toggle(type="button" aria-expanded="false") Menu
      nav.site-nav
        a(href="about.html") O mně
        a(href="blog.html") Blog
        a(href="gamedev.html") Vývoj her
        a(href="design.html") Design
        a(href="illustrations.html") Ilustrace
        a(href="uxdesign.html") UX/UI
      ul.social-links
        li
          a(href="https://instagram.com/viktorbrenek" target="_blank" rel="noreferrer") Instagram
        li
          a(href="https://facebook.com/brenekviktor/" target="_blank" rel="noreferrer") Facebook
        li
          a(href="https://twitch.tv/viktorbrenek" target="_blank" rel="noreferrer") Twitch
        li
          a(href="https://discord.com/invite/2Uj6N5N" target="_blank" rel="noreferrer") Discord
        li
          a(href="https://www.youtube.com/ViktorBrenekYT" target="_blank" rel="noreferrer") Youtube

  main.page-shell
    section.page-hero
      p.eyebrow Nástroje
      h1 UV Mapper shader palety
      p.lead
        | Automatizované přemapování UV podle původní textury do omezené 3x3 palety pro shader workflow v Unity. Tool načte model, změří dominantní barvy trojúhelníků a přepne je na správné paletové UV souřadnice.
      p.hero-kicker
        a.link-pill(href="tools.html") Zpět na přehled nástrojů

    section.tool-panel
      .tool-workbench.tool-workbench--uv-mapper
        .tool-workbench__sidebar
          header.tool-workbench__header
            .tool-workbench__sigil ᛋ
            h2.tool-workbench__title UV Mapper shader palety
          .tool-workbench__body
            .tool-workbench__field
              label.tool-workbench__label(for="uv-model-file") Model
              input#uv-model-file.tool-workbench__input(type="file" accept=".glb,.fbx")
            .tool-workbench__field
              label.tool-workbench__label(for="uv-fallback-texture") Fallback / override textura
              input#uv-fallback-texture.tool-workbench__input(type="file" accept="image/png,image/jpeg,image/webp")
            .tool-workbench__field
              label.tool-workbench__label(for="uv-palette-file") Vlastní paleta 3x3
              input#uv-palette-file.tool-workbench__input(type="file" accept="image/png,image/jpeg,image/webp")
            .tool-workbench__checkbox-row
              label.tool-workbench__checkbox
                input#uv-force-texture(type="checkbox")
                span.tool-workbench__checkbox-box
                span.tool-workbench__checkbox-text Přepsat všechny materiály fallback texturou

            p.tool-workbench__workflow-note
              | Tool je zjednoduseny jen pro `planar cleanup + paletova UV`, takze nize zustavaji jen relevantni slidery pro tenhle workflow.

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-density") Hustota vzorkování
                .tool-workbench__range-row
                  input#uv-density.tool-workbench__range(type="range" min="4" max="12" step="1" value="7")
                  output.tool-workbench__range-value(for="uv-density") 7
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-alpha-threshold") Alpha práh
                .tool-workbench__range-row
                  input#uv-alpha-threshold.tool-workbench__range(type="range" min="0" max="255" step="1" value="32")
                  output.tool-workbench__range-value(for="uv-alpha-threshold") 32

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-analysis-size") Analytické rozlišení
                .tool-workbench__range-row
                  input#uv-analysis-size.tool-workbench__range(type="range" min="256" max="2048" step="128" value="1024")
                  output.tool-workbench__range-value(for="uv-analysis-size") 1024
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-cluster-count") Redukce barev
                .tool-workbench__range-row
                  input#uv-cluster-count.tool-workbench__range(type="range" min="8" max="48" step="2" value="18")
                  output.tool-workbench__range-value(for="uv-cluster-count") 18

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-blur-radius") Vyhlazení textury
                .tool-workbench__range-row
                  input#uv-blur-radius.tool-workbench__range(type="range" min="0" max="4" step="1" value="1")
                  output.tool-workbench__range-value(for="uv-blur-radius") 1
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-majority-passes") Cleanup průchodů
                .tool-workbench__range-row
                  input#uv-majority-passes.tool-workbench__range(type="range" min="0" max="3" step="1" value="1")
                  output.tool-workbench__range-value(for="uv-majority-passes") 1

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-color-tolerance") Tolerance odstínů
                .tool-workbench__range-row
                  input#uv-color-tolerance.tool-workbench__range(type="range" min="0" max="180" step="5" value="60")
                  output.tool-workbench__range-value(for="uv-color-tolerance") 60
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-shadow-threshold") Potlačení stínů
                .tool-workbench__range-row
                  input#uv-shadow-threshold.tool-workbench__range(type="range" min="0" max="140" step="5" value="55")
                  output.tool-workbench__range-value(for="uv-shadow-threshold") 55

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-planar-normal") Normal tolerance
                .tool-workbench__range-row
                  input#uv-planar-normal.tool-workbench__range(type="range" min="2" max="45" step="1" value="12")
                  output.tool-workbench__range-value(for="uv-planar-normal") 12
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-planar-distance") Planar tolerance
                .tool-workbench__range-row
                  input#uv-planar-distance.tool-workbench__range(type="range" min="1" max="120" step="1" value="18")
                  output.tool-workbench__range-value(for="uv-planar-distance") 18

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-planar-region") Max region size
                .tool-workbench__range-row
                  input#uv-planar-region.tool-workbench__range(type="range" min="8" max="600" step="4" value="120")
                  output.tool-workbench__range-value(for="uv-planar-region") 120
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="uv-planar-rescue") Low-confidence rescue
                .tool-workbench__range-row
                  input#uv-planar-rescue.tool-workbench__range(type="range" min="0" max="100" step="5" value="35")
                  output.tool-workbench__range-value(for="uv-planar-rescue") 35

            p.tool-workbench__help
              | Import `FBX` i `GLB` je podporovany, export jde do `GLB`. Tool ted cili ciste na co nejlepsi planar cleanup workflow.
            p#uv-status.tool-workbench__status Připraveno. Nahraj model a případně fallback texturu nebo vlastní paletu.

            .tool-workbench__actions
              button#uv-process-btn.world-map__button(type="button" disabled) Redukovat barvy a přemapovat UV
              button#uv-reset-btn.world-map__button.world-map__button--secondary(type="button" disabled) Obnovit originál
              button#uv-export-btn.world-map__button.world-map__button--secondary(type="button" disabled) Stáhnout GLB
              button#uv-export-png-btn.world-map__button.world-map__button--secondary(type="button" disabled) Stáhnout PNG textury
              button#uv-report-btn.world-map__button.world-map__button--secondary(type="button" disabled) Stáhnout report JSON
        .tool-workbench__canvas-panel
          .tool-workbench__canvas-shell.tool-workbench__canvas-shell--uv-mapper
            p.tool-workbench__canvas-title Náhled modelu a palety
            p.tool-workbench__canvas-text
              | V náhledu vidíš model už s paletovou texturou. Statistiky ukazují, kolik trojúhelníků se přemapovalo, kde chyběla textura a jak jisté bylo rozhodnutí při vzorkování.
            .tool-workbench__canvas-frame.tool-workbench__canvas-frame--viewport
              #uv-mapper-stage.uv-mapper-stage
            .uv-mapper-meta
              article.sonics-meta-card
                p.sonics-meta-card__label Meshes
                p#uv-stat-meshes.sonics-meta-card__value 0
              article.sonics-meta-card
                p.sonics-meta-card__label Trojúhelníky
                p#uv-stat-triangles.sonics-meta-card__value 0
              article.sonics-meta-card
                p.sonics-meta-card__label Bez textury
                p#uv-stat-fallback.sonics-meta-card__value 0
              article.sonics-meta-card
                p.sonics-meta-card__label Průměrná jistota
                p#uv-stat-confidence.sonics-meta-card__value 0 %
            .uv-mapper-secondary
              article.uv-mapper-card
                p.uv-mapper-card__label Aktivní paleta
                canvas#uv-palette-preview.uv-mapper-palette(width="240" height="240")
              article.uv-mapper-card
                p.uv-mapper-card__label Analytická textura
                canvas#uv-analysis-preview.uv-mapper-palette(width="240" height="240")
              article.uv-mapper-card
                p.uv-mapper-card__label Poslední report
                pre#uv-report-preview.uv-mapper-report Čekám na zpracování...
