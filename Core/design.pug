doctype html
head
  title Design | Viktor Břenek
  meta(content="text/html;charset=utf-8", http-equiv="Content-Type")
  meta(content="utf-8", http-equiv="encoding")
  meta(name="author" content="Viktor Brenek")
  meta(name="description" content="Osobní blog a portfolio")
  meta(property="og:image" content="http://viktorbrenek.github.io/assets/images/icon-512.png")
  meta(name="viewport" content="width=device-width,initial-scale=1.0")
  link(rel="stylesheet", href="styles.css")
  link(rel="icon" href="assets/images/favicon.png" sizes="any")
  link(rel="icon" href="assets/images/icon.svg" type="image/svg+xml")
  link(rel="apple-touch-icon" href="assets/images/apple-touch-icon.png")
  link(rel="manifest" href="/manifest.json")
  script(src="site.js" defer)

body(data-page="design")
  header.site-header
    .site-header__inner
      a.brand(href="index.html")
        span.brand__sigil V
        span.brand__text
          span.brand__eyebrow Archiv designu
          span.brand__name Viktor Břenek
      button.nav-toggle(type="button" aria-expanded="false") Menu
      nav.site-nav
        a(href="about.html") O mně
        a(href="blog.html") Blog
        a(href="gamedev.html") Vývoj her
        a(href="design.html") Design
        a(href="illustrations.html") Ilustrace
        a(href="uxdesign.html") UX/UI
      ul.social-links
        li
          a(href="https://instagram.com/viktorbrenek" target="_blank" rel="noreferrer") Instagram
        li
          a(href="https://facebook.com/brenekviktor/" target="_blank" rel="noreferrer") Facebook
        li
          a(href="https://discord.com/invite/2Uj6N5N" target="_blank" rel="noreferrer") Discord

  main.page-shell
    section.page-hero
      p.eyebrow Grafický design
      h1 Logotypy, plakáty a marketing
      p.lead Kolekce mých logotypů, plakátů, bannerů a další marketingové práce.

    section.section-card
      h2.section-title Logotypy
      p.hero-kicker Kolekce logotypů pro různé firmy a projekty v České republice.
      .gallery-grid
        each image in ["huzova.jpg", "mogi.jpg", "mor.jpg", "db.jpg", "vb.jpg", "bla.jpg", "bikes.jpg", "grow.jpg", "sante.jpg", "village.jpg", "vlach.jpg", "vyroci.jpg", "sims.jpg", "hran.jpg"]
          figure.media-card
            .media-card__media
              img(src=`assets/images/${image}` alt="Návrh logotypu" loading="lazy")

    section.section-card
      h2.section-title Marketing, plakáty, bannery
      p.hero-kicker Kolekce plakátů, bannerů a další marketingové tvorby.
      .gallery-grid.gallery-grid--wide
        figure.media-card
          .media-card__media
            img(src="assets/images/pravek1.jpg" alt="Návrh plakátu" loading="lazy")
        figure.media-card
          .media-card__media
            img(src="assets/images/pravek2.jpg" alt="Návrh plakátu" loading="lazy")
      .gallery-grid
        each image in ["stan.jpg", "uterka.jpg", "plakat.jpg"]
          figure.media-card
            .media-card__media
              img(src=`assets/images/${image}` alt="Marketingový návrh" loading="lazy")

  footer.site-footer
