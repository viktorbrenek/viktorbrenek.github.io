doctype html
head
  title Generátor avatarů | Viktor Břenek
  meta(content="text/html;charset=utf-8", http-equiv="Content-Type")
  meta(content="utf-8", http-equiv="encoding")
  meta(name="author" content="Viktor Brenek")
  meta(name="description" content="Generátor avatarů a portrétů z SVG vrstev")
  meta(property="og:image" content="http://viktorbrenek.github.io/assets/images/icon-512.png")
  meta(name="viewport" content="width=device-width,initial-scale=1.0")
  link(rel="stylesheet", href="styles.css")
  link(rel="icon" href="assets/images/favicon.png" sizes="any")
  link(rel="icon" href="assets/images/icon.svg" type="image/svg+xml")
  link(rel="apple-touch-icon" href="assets/images/apple-touch-icon.png")
  link(rel="manifest" href="/manifest.json")
  script(src="site.js" defer)
  script(src="tools.js" defer)

body(data-page="tool-avatar")
  header.site-header
    .site-header__inner
      a.brand(href="index.html")
        span.brand__sigil V
        span.brand__text
          span.brand__eyebrow Nástroje
          span.brand__name Viktor Břenek
      button.nav-toggle(type="button" aria-expanded="false") Menu
      nav.site-nav
        a(href="about.html") O mně
        a(href="blog.html") Blog
        a(href="gamedev.html") Vývoj her
        a(href="design.html") Design
        a(href="illustrations.html") Ilustrace
        a(href="uxdesign.html") UX/UI
      ul.social-links
        li
          a(href="https://instagram.com/viktorbrenek" target="_blank" rel="noreferrer") Instagram
        li
          a(href="https://facebook.com/brenekviktor/" target="_blank" rel="noreferrer") Facebook
        li
          a(href="https://discord.com/invite/2Uj6N5N" target="_blank" rel="noreferrer") Discord

  main.page-shell
    section.page-hero
      p.eyebrow Nástroje
      h1 Generátor avatarů
      p.lead
        | Portrétní generátor z tvých SVG vrstev. Seed mění iterace, barvy kůže, vlasů, očí, oblečení i pozadí, ale všechno jde pak doladit ručně.
      p.hero-kicker
        a.link-pill(href="tools.html") Zpět na přehled nástrojů

    section.tool-panel
      .tool-workbench
        .tool-workbench__sidebar
          header.tool-workbench__header
            .tool-workbench__sigil ᚷ
            h2.tool-workbench__title Generátor avatarů
          .tool-workbench__body
            .tool-workbench__field
              label.tool-workbench__label(for="avatar-name") Jméno postavy (seed)
              input#avatar-name.tool-workbench__input(type="text" value="Poutník z popelavých břehů" autocomplete="off")
            .tool-workbench__checkbox-row
              label.tool-workbench__checkbox
                input#avatar-auto-seed(type="checkbox" checked)
                span.tool-workbench__checkbox-box
                span.tool-workbench__checkbox-text Vázat vzhled na jméno a iteraci
            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-race") Rasa
                select#avatar-race.tool-workbench__input.manual-input
                  option(value="eastlander") Eastlander
                  option(value="maor") Maor
                  option(value="valrug") Valrug
                  option(value="robot") Robot
                  option(value="kabadeon") Kabadeon
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-iteration") Iterace
                input#avatar-iteration.tool-workbench__input.manual-input(type="number" min="0" max="999" step="1" value="0")
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-hair-style") Vlasy
                select#avatar-hair-style.tool-workbench__input.manual-input
                  option(value="hair1") Dlouhé / těžké
                  option(value="hair2") Kratší / divočejší
                  option(value="hair3") Koruna / rohy
                  option(value="none") Bez vlasů
            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-beard-style") Vousy
                select#avatar-beard-style.tool-workbench__input.manual-input
                  option(value="auto") Automaticky
                  option(value="none") Bez vousů
                  option(value="beard") Plnovous
                  option(value="beard2") Rozvětvený vous
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-bg-style") Pozadí
                select#avatar-bg-style.tool-workbench__input.manual-input
                  option(value="auto") Automaticky
                  option(value="embers") Popel a žhnutí
                  option(value="forest") Mech a mlha
                  option(value="dusk") Soumrak
                  option(value="arcane") Arkanické halo
            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-skin-color") Kůže
                input#avatar-skin-color.tool-workbench__input.tool-workbench__input--color.manual-input(type="color" value="#c78a58")
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-hair-color") Vlasy
                input#avatar-hair-color.tool-workbench__input.tool-workbench__input--color.manual-input(type="color" value="#4b2318")
            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-eye-color") Oči
                input#avatar-eye-color.tool-workbench__input.tool-workbench__input--color.manual-input(type="color" value="#5a8757")
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="avatar-cloth-color") Oděv
                input#avatar-cloth-color.tool-workbench__input.tool-workbench__input--color.manual-input(type="color" value="#3e4c5f")
            .tool-workbench__field
              label.tool-workbench__label(for="avatar-accent-color") Akcent / aura
              input#avatar-accent-color.tool-workbench__input.tool-workbench__input--color.manual-input(type="color" value="#d8a247")
            .tool-workbench__actions
              button#btn-generate-avatar.world-map__button(type="button") Vygenerovat avatar
              button#btn-next-avatar.world-map__button.world-map__button--secondary(type="button") Další iterace
              button#btn-download-avatar.world-map__button.world-map__button--secondary(type="button") Stáhnout PNG
        .tool-workbench__canvas-panel
          .tool-workbench__canvas-shell
            p.tool-workbench__canvas-title Náhled portrétu
            p.tool-workbench__canvas-text
              | Avatar skládá vrstvy vlasů, hlavy, obličeje a těla z lokálních SVG. Seed drží konzistentní variantu, ale barvy i styl si můžeš kdykoliv přebarvit ručně.
            .tool-workbench__canvas-frame
              canvas#avatar-canvas(width="512" height="512")

  footer.site-footer
