doctype html
head
  title Arcanum Convertor | Viktor Břenek
  meta(content="text/html;charset=utf-8", http-equiv="Content-Type")
  meta(content="utf-8", http-equiv="encoding")
  meta(name="author" content="Viktor Brenek")
  meta(name="description" content="Konvertor herních assetů pro Arcanum – exportuje indexované .ART soubory")
  meta(property="og:image" content="http://viktorbrenek.github.io/assets/images/icon-512.png")
  meta(name="viewport" content="width=device-width,initial-scale=1.0")
  link(rel="stylesheet", href="styles.css")
  link(rel="icon" href="assets/images/favicon.png" sizes="any")
  link(rel="icon" href="assets/images/icon.svg" type="image/svg+xml")
  link(rel="apple-touch-icon" href="assets/images/apple-touch-icon.png")
  link(rel="manifest" href="/manifest.json")
  script(src="site.js" defer)
  script(src="arcanum-convertor.js" defer)

body(data-page="tool-arcanum-convertor")
  header.site-header
    .site-header__inner
      a.brand(href="index.html")
        span.brand__sigil V
        span.brand__text
          span.brand__eyebrow Nástroje
          span.brand__name Viktor Břenek
      button.nav-toggle(type="button" aria-expanded="false") Menu
      nav.site-nav
        a(href="about.html") O mně
        a(href="blog.html") Blog
        a(href="gamedev.html") Vývoj her
        a(href="design.html") Design
        a(href="illustrations.html") Ilustrace
        a(href="uxdesign.html") UX/UI
      ul.social-links
        li
          a(href="https://instagram.com/viktorbrenek" target="_blank" rel="noreferrer") Instagram
        li
          a(href="https://facebook.com/brenekviktor/" target="_blank" rel="noreferrer") Facebook
        li
          a(href="https://twitch.tv/viktorbrenek" target="_blank" rel="noreferrer") Twitch
        li
          a(href="https://discord.com/invite/2Uj6N5N" target="_blank" rel="noreferrer") Discord
        li
          a(href="https://www.youtube.com/ViktorBrenekYT" target="_blank" rel="noreferrer") Youtube

  main.page-shell
    section.page-hero
      p.eyebrow Nástroje
      h1 Arcanum Convertor
      p.lead
        | Konvertor herních assetů pro Arcanum: Of Steamworks and Magick Obscura. Nahraje obrázek, nastaví rozměry, izometrický sklon a průhlednost, pak vygeneruje indexovaný .ART soubor s paletou kompatibilní s herním enginem. Obsahuje i prohlížeč existujících .ART souborů.
      p.hero-kicker
        a.link-pill(href="tools.html") Zpět na přehled nástrojů

    section.tool-panel
      .tool-workbench.tool-workbench--arcanum-convertor
        .tool-workbench__sidebar
          header.tool-workbench__header
            .tool-workbench__sigil ᚲ
            h2.tool-workbench__title Arcanum Convertor
          .tool-workbench__body
            .tool-workbench__field
              label.tool-workbench__label(for="upload") Obrázek
              input#upload.tool-workbench__input(type="file" accept="image/*")

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="width") Šířka (px)
                input#width.tool-workbench__input(type="number" value="40" min="1")
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="height") Výška (px)
                input#height.tool-workbench__input(type="number" value="40" min="1")

            .tool-workbench__row
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="centerX") Střed X
                input#centerX.tool-workbench__input(type="number" value="20")
              .tool-workbench__field
                label.tool-workbench__label.tool-workbench__label--small(for="centerY") Střed Y
                input#centerY.tool-workbench__input(type="number" value="20")

            .tool-workbench__checkbox-row
              label.tool-workbench__checkbox
                input#isoGround(type="checkbox")
                span.tool-workbench__checkbox-box
                span.tool-workbench__checkbox-text Ground sprite (Izometrický)

            .tool-workbench__checkbox-row
              label.tool-workbench__checkbox
                input#removeBg(type="checkbox")
                span.tool-workbench__checkbox-box
                span.tool-workbench__checkbox-text Odstranit barvu pozadí

            #bgColorRow.tool-workbench__field(style="display:none")
              label.tool-workbench__label(for="bgColor") Barva pozadí
              input#bgColor.tool-workbench__input.tool-workbench__input--color(type="color" value="#ffffff")

            #downloadArea.tool-workbench__actions(style="display:none")
              button#downloadBtn.world-map__button(type="button") Stáhnout .ART

            p.tool-workbench__help
              | Pixel index 0 je transparentní (černý). Engine Arcanumu mapuje paletu podle pořadí frekvence – nejčastější barvy jdou první.

            hr(style="border:none;border-top:1px solid rgba(194,181,163,0.12);margin:16px 0")

            .tool-workbench__field
              label.tool-workbench__label(for="artUpload") Prohlížeč .ART souboru
              input#artUpload.tool-workbench__input(type="file" accept=".art")

        .tool-workbench__canvas-panel
          .tool-workbench__canvas-shell.tool-workbench__canvas-shell--arcanum-convertor
            p.tool-workbench__canvas-title Export náhled
            p.tool-workbench__canvas-text
              | Pixel-perfect náhled výsledného spritu. Barvy se indexují do 256barevné palety podle frekvence výskytu – černá (index 0) slouží jako průhlednost.
            .tool-workbench__canvas-frame
              canvas#previewCanvas

            #artPreviewArea(style="display:none")
              p.tool-workbench__canvas-title Prohlížeč .ART
              p#artInfo.tool-workbench__status
              .tool-workbench__canvas-frame
                canvas#artCanvas

  footer.site-footer
